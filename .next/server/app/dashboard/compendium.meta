{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/compendium/layout,_N_T_/dashboard/compendium/page,_N_T_/dashboard/compendium"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/compendium/__PAGE__",
    "/dashboard/compendium",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}